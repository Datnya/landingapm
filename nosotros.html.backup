                    </div>
                </div>
            </div>
            <div
                style="margin-top: 50px; padding-top: 20px; border-top: 1px solid rgba(255,255,255,0.1); text-align: center; font-size: 0.8rem; opacity: 0.5;">
                <p>&copy; 2026 APM Group. Todos los derechos reservados.</p>
            </div>
        </div>
    </footer>

